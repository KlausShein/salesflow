{
  "name": "printpos-pro",
  "version": "3.0.3",
  "description": "PrintPOS Pro — Print Shop Sales Tracker & Financial Distribution System",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "type-check": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:publish": "npm run build && electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.salesflow.printpos",
    "productName": "Sales Flow",
    "copyright": "Copyright © 2026 Sales Flow",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "publish": {
      "provider": "github",
      "owner": "KlausShein",
      "repo": "salesflow",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/app-icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/app-icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/app-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sales Flow",
      "installerIcon": "src/assets/app-icon.ico",
      "installerHeaderIcon": "src/assets/app-icon.ico"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    }
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.19.4",
    "@supabase/supabase-js": "^2.106.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "express": "^4.22.2",
    "lottie-react": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "wait-on": "^9.0.10"
  }
}
